{
  "name": "sliver-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run prebuild && concurrently -k -n prebuild,dev \"npm run prebuild:watch -- --skip-initial\" \"next dev --webpack\"",
    "build": "npm run prebuild && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "prebuild": "node ./prebuild/run-prebuild.js",
    "prebuild:watch": "node ./prebuild/watch.js",
    "offline": "npm run build && zip -r www.zip ./out",
    "postinstall": "node ./prebuild/run-prebuild.js"
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query": "^5.100.6",
    "asciinema-player": "^3.15.1",
    "fuse.js": "^7.3.0",
    "lunr": "^2.3.9",
    "mermaid": "^11.14.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/lunr": "^2.3.7",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "dompurify": "^3.4.2",
    "postcss": "^8.5.13",
    "uuid": "^14.0.0"
  }
}
